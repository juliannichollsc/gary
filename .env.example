# GARY — environment (copy to .env). Model/CLI-agnostic: pick ONE backend.
# Auth is normally the CLI's own login; only set a key if your chosen CLI/model needs one.
# Keys are read by the CLI; GARY injects them into the spawned PTY process env.

# Which AI coding CLI GARY launches in the PTY (gemini | claude | opencode | codex)
GARY_CLI=gemini

# --- Provider keys (optional; prefer the CLI's own login) ---
GEMINI_API_KEY=your_gemini_api_key_here        # free tier: aistudio.google.com/apikey
# ANTHROPIC_API_KEY=your_anthropic_key_here
# OPENAI_API_KEY=your_openai_key_here

# --- Automation browser (job sourcing/applying over CDP) ---
GARY_BROWSER_PORT=9333
